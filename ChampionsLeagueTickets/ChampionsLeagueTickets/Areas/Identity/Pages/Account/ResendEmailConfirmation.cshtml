@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Verstuur opnieuw de E-mailbevestiging";
}

<h1>@ViewData["Title"]</h1>
<h2>Geef uw E-mailadres in.</h2>
<hr />
<div class="row">
    <div class="row justify-content-center">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" aria-required="true" placeholder="naam@voorbeeld.com" />
                <label asp-for="Input.Email" class="form-label"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn-golden">Verstuur opnieuw</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
