@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "E-mail is bevestigd";
}

<div class="row justify-content-center">
    <h1>@ViewData["Title"]</h1>
    <partial name="_StatusMessage" model="Model.StatusMessage" />
    <p>
        Uw E-mail is bevestigd. Dankuwel! U kunt nu doorgaan naar de applicatie.
    </p>
    <a class="btn btn-primary mt-2" asp-page="/Account/Login" asp-area="Identity">Ga naar login</a>
    <img src="~/images/blije_voetballers.jpg" alt="Blije voetballers" />
</div>