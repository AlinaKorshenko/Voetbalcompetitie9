
<style>
    .ucl {
        font-family: 'Barlow', sans-serif;
        background: #0d0e1a;
        color: #e8eaf6;
        overflow: hidden;
    }

    .hero {
        position: relative;
        min-height: 540px;
        display: flex;
        align-items: center;
        background: #0d0e1a;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 70% 50%, #1a1f5e 0%, #0d0e1a 65%);
    }

    .stars {
        position: absolute;
        inset: 0;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 3.5rem 2.5rem;
        max-width: 560px;
    }

    .ucl-emblem {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    .star-row {
        display: flex;
        gap: 3px;
    }

    .star {
        width: 12px;
        height: 12px;
    }

    .ucl-wordmark {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 13px;
        letter-spacing: 4px;
        color: #c9aa71;
    }

    .hero h1 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(3.2rem, 9vw, 6.5rem);
        line-height: .9;
        color: #fff;
        margin: 0 0 .5rem;
    }

        .hero h1 .gold {
            color: #c9aa71;
        }

        .hero h1 .blue {
            color: #8b9fe8;
        }

    .hero-sub {
        font-size: 1rem;
        line-height: 1.75;
        color: #8b9cc8;
        max-width: 400px;
        margin-bottom: 2rem;
        font-style: italic;
    }

        .hero-sub strong {
            color: #e8eaf6;
            font-style: normal;
        }

    .btn-ucl {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: 'Barlow', sans-serif;
        font-size: .9rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: .85rem 2rem;
        border-radius: 3px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
    }

    .btn-gold {
        background: #c9aa71;
        color: #0d0e1a;
    }

        .btn-gold:hover {
            background: #dfc088;
        }

    .btn-ghost {
        background: transparent;
        color: #c9aa71;
        border: 1.5px solid #c9aa71;
    }

        .btn-ghost:hover {
            background: rgba(201,170,113,.12);
        }

    .cta-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .player-wrap {
        position: absolute;
        right: 0;
        bottom: 0;
        width: 44%;
        max-width: 400px;
        z-index: 1;
    }

        .player-wrap img {
            width: 100%;
            height: 460px;
            object-fit: cover;
            object-position: top;
            -webkit-mask-image: linear-gradient(to left, black 40%, transparent 90%);
            mask-image: linear-gradient(to left, black 40%, transparent 90%);
            filter: brightness(.85) contrast(1.1);
        }

    .divider {
        height: 3px;
        background: linear-gradient(to right, #c9aa71 0%, #8b9fe8 50%, #c9aa71 100%);
    }

    .info-band {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 320px;
    }

    .info-text {
        background: #12153a;
        padding: 3rem 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .section-tag {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #c9aa71;
        margin-bottom: 1rem;
    }

    .info-text h2 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.8rem;
        color: #fff;
        margin: 0 0 1rem;
        line-height: 1;
    }

    .info-text p {
        color: #8b9cc8;
        line-height: 1.75;
        margin-bottom: 1.5rem;
        font-size: .95rem;
    }

    .info-img {
        position: relative;
        overflow: hidden;
    }

        .info-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(.6) saturate(1.3);
        }

        .info-img::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, #12153a 0%, transparent 45%);
        }

    .matches-band {
        background: #0d0e1a;
        padding: 3rem 2.5rem;
    }

        .matches-band h2 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.8rem;
            color: #fff;
            margin: 0 0 .5rem;
            line-height: 1;
        }

        .matches-band p {
            color: #8b9cc8;
            margin-bottom: 2rem;
            max-width: 480px;
        }

        .matches-band img {
            width: 100%;
            max-height: 360px;
            object-fit: cover;
            border-radius: 4px;
            margin-bottom: 2rem;
            border: 1px solid rgba(201,170,113,.25);
            filter: brightness(.7) saturate(1.2);
        }

    .info-band {
        grid-template-columns: 1fr;
    }

    }
    .info-band {
        grid-template-columns: 1fr
    }

    }</style>

<div class="ucl">
    <h2 style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Champions League homepagina</h2>

    <section class="hero">
        <div class="hero-bg"></div>

        <svg class="stars" viewBox="0 0 800 540" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;opacity:.35">
            <circle cx="60" cy="80" r="1.2" fill="#c9aa71" />
            <circle cx="180" cy="40" r="1" fill="#8b9fe8" />
            <circle cx="300" cy="110" r="1.5" fill="#c9aa71" />
            <circle cx="420" cy="30" r="1" fill="#fff" />
            <circle cx="100" cy="200" r="1" fill="#8b9fe8" />
            <circle cx="230" cy="160" r="1.2" fill="#c9aa71" />
            <circle cx="140" cy="300" r="1" fill="#fff" />
            <circle cx="350" cy="250" r="1.3" fill="#8b9fe8" />
            <circle cx="50" cy="380" r="1" fill="#c9aa71" />
            <circle cx="200" cy="420" r="1.2" fill="#fff" />
            <circle cx="320" cy="380" r="1" fill="#8b9fe8" />
        </svg>

        <div class="hero-content">
            <div class="ucl-emblem">
                <svg class="star-row" viewBox="0 0 80 14" width="80" height="14" xmlns="http://www.w3.org/2000/svg">
                    <polygon points="7,1 8.8,5.5 13.5,5.5 9.8,8.5 11.2,13 7,10.2 2.8,13 4.2,8.5 0.5,5.5 5.2,5.5" fill="#c9aa71" />
                    <polygon points="27,1 28.8,5.5 33.5,5.5 29.8,8.5 31.2,13 27,10.2 22.8,13 24.2,8.5 20.5,5.5 25.2,5.5" fill="#c9aa71" />
                    <polygon points="47,1 48.8,5.5 53.5,5.5 49.8,8.5 51.2,13 47,10.2 42.8,13 44.2,8.5 40.5,5.5 45.2,5.5" fill="#c9aa71" />
                    <polygon points="67,1 68.8,5.5 73.5,5.5 69.8,8.5 71.2,13 67,10.2 62.8,13 64.2,8.5 60.5,5.5 65.2,5.5" fill="#c9aa71" />
                </svg>
                <span class="ucl-wordmark">UEFA Champions League</span>
            </div>

            <h1>
                Het Grootste<br />
                <span class="gold">Podium</span> van<br />
                <span class="blue">Europa</span>
            </h1>
            <p class="hero-sub">
                Alle topteams. De iconische beker.<br />
                <strong>En ú kunt erbij zijn. Mis het niet.</strong>
            </p>
            <div class="cta-row">
                <button class="btn-ucl btn-gold" asp-controller="Ticket" asp-action="Matches">Wedstrijden bekijken</button>
                <button class="btn-ucl btn-ghost">Meer info</button>
            </div>
        </div>

        <div class="player-wrap">
            <img src="~/images/soccer_player.jpg" alt="Voetbalspeler" />
        </div>
    </section>

    <div class="divider"></div>

    <section class="info-band">
        <div class="info-text">
            <div class="section-tag">Het toernooi</div>
            <h2>32 clubs. Één beker.</h2>
            <p>Van de groepsfase tot de iconische finale — elke wedstrijd telt. De beste clubs uit Europa strijden om de meest begeerde prijs in het clubvoetbal.</p>
            <button class="btn-ucl btn-gold" style="width:fit-content;">Ontdek meer</button>
        </div>
        <div class="info-img">
            <img src="~/images/stadion.jpg" alt="Stadion" />
        </div>
    </section>

    <div class="divider"></div>

    <section class="matches-band">
        <div class="section-tag">Agenda</div>
        <h2>Mis de Topwedstrijden Niet</h2>
        <p>Bekijk alle aankomende wedstrijden en bestel uw tickets.</p>
        <button asp-controller="Ticket" asp-action="Matches" class="btn-ucl btn-gold">Wedstrijden</button>
    </section>
</div>
