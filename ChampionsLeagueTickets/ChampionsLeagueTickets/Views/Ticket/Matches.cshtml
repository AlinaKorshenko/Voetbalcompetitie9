@model IEnumerable<ChampionsLeagueTickets.ViewModels.MatchVM>

@{
    ViewData["Title"] = "Matches";

    var clubs = Model?
        .SelectMany(m => new[] { m.homeTeamName, m.awayTeamName })
        .Where(c => !string.IsNullOrWhiteSpace(c))
        .Distinct()
        .OrderBy(c => c)
        .ToList();
}

@if (Model != null && Model.Any())
{
    <h1>De wedstrijden</h1>
    <p>
        Stuk voor stuk topmatches in de beste Europese stadions.
        <br />
        Mis ze niet.
    </p>

    <div class="mb-4">
        <label for="clubFilter" class="form-label fw-bold">Filter op club</label>

        <select id="clubFilter" class="form-select" style="max-width: 350px;">
            <option value="">Alle clubs</option>

            @foreach (var club in clubs)
            {
                <option value="@club">
                    @club
                </option>
            }
        </select>
    </div>

    <table id="matchesTable" class="table border-0">
        <thead>
            <tr>
                <th>Matches</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var match in Model)
            {
                <tr class="match-card"
                    data-home="@match.homeTeamName"
                    data-away="@match.awayTeamName">
                    <td>
                        <a asp-controller="Ticket"
                           asp-action="ChooseSeats"
                           asp-route-matchID="@match.MatchId"
                           class="text-decoration-none @(match.IsKoopbaar ? "text-dark" : "text-muted")"
                           style="pointer-events:@(match.IsKoopbaar ? "auto" : "none");">

                            <div class="card p-3 shadow-sm mb-3 @(match.IsKoopbaar ? "" : "opacity-50")">
                                <div class="d-flex justify-content-between align-items-center">

                                    <div>
                                        <h5 class="mb-0">@match.stadionName</h5>

                                        @if (match.IsKoopbaar)
                                        {
                                            <span class="badge bg-success">Tickets beschikbaar</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Binnenkort beschikbaar</span>
                                            <br />
                                            <small class="text-muted">
                                                Vanaf: @match.DatumTijdStartMatch.AddMonths(-1).ToString("dd/MM/yyyy")
                                            </small>
                                        }
                                    </div>

                                    <div>
                                        @match.homeTeamName
                                        <span class="badge bg-dark mx-2">VS</span>
                                        @match.awayTeamName
                                    </div>

                                    <div class="text-end">
                                        <strong>@match.DatumTijdStartMatch.ToString("dd/MM/yyyy")</strong><br />
                                        <span>@match.DatumTijdStartMatch.ToString("HH:mm")</span>
                                    </div>

                                </div>
                            </div>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <p id="noMatchesMessage" class="text-warning fw-bold d-none">
        Geen wedstrijden gevonden voor deze club.
    </p>
}
else
{
    <p>Er is een fout</p>
}

@section Scripts {
    <script>
        const clubFilter = document.getElementById("clubFilter");
        const rows = document.querySelectorAll(".match-card");
        const noMatchesMessage = document.getElementById("noMatchesMessage");

        clubFilter.addEventListener("change", function () {
            const selectedClub = this.value;
            let visibleCount = 0;

            rows.forEach(row => {
                const home = row.dataset.home;
                const away = row.dataset.away;

                const isMatch =
                    selectedClub === "" ||
                    home === selectedClub ||
                    away === selectedClub;

                row.style.display = isMatch ? "" : "none";

                if (isMatch) {
                    visibleCount++;
                }
            });

            noMatchesMessage.classList.toggle("d-none", visibleCount > 0);
        });
    </script>
}