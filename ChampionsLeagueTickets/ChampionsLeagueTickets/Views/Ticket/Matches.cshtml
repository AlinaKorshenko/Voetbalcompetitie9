@model IEnumerable<ChampionsLeagueTickets.ViewModels.MatchVM>

@{
    ViewData["Title"] = "Matches";
}

@section Styles {
   <link href="~/lib/datatables/css/jquery.datatables.min.css" rel="stylesheet" />
}

@if (Model != null){
{
    <table id="matchesTable" class="table border-0">
            <thead>
                <tr>
                    <th>Matches</th>
                </tr>
            </thead>
        <tbody>
            @foreach (var match in Model)
            {
               <tr class="match-card">
                    <td>
                        <div class="card p-3 shadow-sm mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-0">
                                       @match.stadionName
                                    </h5>
                                </div>
                                    <div>
                                        @match.homeTeamName
                                        <span class="badge bg-dark mx-2">VS</span>
                                        @match.awayTeamName
                                    </div>
                                <div class="text-end">
                                    <strong>
                                        @match.DatumTijdStartMatch.ToString("dd/MM/yyyy")
                                    </strong><br/>
                                    <span>
                                        @match.DatumTijdStartMatch.ToString("HH:mm")
                                    </span>
                                </div>

                            </div>
                        </div>
                    </td>
               </tr>
            }
        </tbody>
    </table>
 }
}
else
 {
    <p>Er is een fout</p>
 }
@section Scripts {
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script>
        $(() => {
        $('#matchesTable').DataTable();
        });
    </script>
}
