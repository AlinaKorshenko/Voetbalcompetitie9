@model ChampionsLeagueTickets.ViewModels.AbonementStoelVM
@{
    ViewData["Title"] = "Kies een plaats";
}

<h1>Kies een plaats</h1>

<form asp-action="ChooseSeats" method="post" id="seatForm">
    <input type="hidden" asp-for="StadionID" />
    <input type="hidden" asp-for="SeizoenId" />
    <input type="hidden" asp-for="VakNummer" />
    <input type="hidden" asp-for="VakNaam" />

    <div class="mb-3">
        <label class="form-label fw-bold">Vak</label>
        <p>@Model.VakNaam</p>
    </div>

    <div class="mb-3">
        <label asp-for="RijNummer" class="form-label">Rij</label>
        <select asp-for="RijNummer"
                asp-items="Model.RijenLijst"
                class="form-control"
                id="RijNummer">
            <option value="">-- Kies rij --</option>
        </select>
    </div>

    @if (Model.StoelenLijst != null)
    {
        <div class="mb-3">
            <label asp-for="GeselecteerdeZitplaatsId" class="form-label">Stoel</label>
            <select asp-for="GeselecteerdeZitplaatsId"
                    asp-items="Model.StoelenLijst"
                    class="form-control"
                    id="GeselecteerdeZitplaatsId">
                <option value="">-- Kies stoel --</option>
            </select>
        </div>
    }
</form>

@if (!string.IsNullOrEmpty(Model.GeselecteerdeZitplaatsId))
{
    <form asp-action="OverzichtInfoAbonement" method="post">
        <input type="hidden" asp-for="StadionID" />
        <input type="hidden" asp-for="SeizoenId" />
        <input type="hidden" asp-for="VakNummer" />
        <input type="hidden" asp-for="RijNummer" />
        <input type="hidden" asp-for="GeselecteerdeZitplaatsId" />
        <button type="submit" class="btn btn-success">Verder gaan</button>
    </form>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#RijNummer').on('change', function () {
                $('#seatForm').submit();
            });
            $('#GeselecteerdeZitplaatsId').on('change', function () {
                $('#seatForm').submit();
            });
        });
    </script>
}