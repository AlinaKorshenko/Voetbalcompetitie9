@model IEnumerable<ChampionsLeagueTickets.ViewModels.AbonnementenInformatieVM>
@{
    ViewData["Title"] = "Abonnementen";
}

@if (Model != null)
{
    <h2 class="mb-4">Abonnementen</h2>
    <p>
        Ontgrendel een wereld van voetbalplezier.
        <br />
        Met een abonnement kunt u gedurende het hele seizoen kijken naar matchen in het thuisstadion
        van uw favoriete team.
    </p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var abonnement in Model)
        {
            <div class="col">
                <a asp-controller="Abonnement"
                   asp-action="ChooseSeats"
                   asp-route-stadionId="@abonnement.StadionId"
                   asp-route-seizoenId="@abonnement.SeizoenId"
                   class="text-decoration-none @(abonnement.IsKoopbaar ? "text-dark" : "text-muted")"
                   style="pointer-events:@(abonnement.IsKoopbaar ? "auto" : "none");">
                    <div class="card h-100 shadow-sm p-3 @(abonnement.IsKoopbaar ? "" : "opacity-50")">
                        <div class="card-body">
                            <h4 class="card-title mb-1">@abonnement.StadionNaam</h4>
                            @if (abonnement.IsKoopbaar)
                            {
                                <span class="badge bg-success mb-2">Beschikbaar</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary mb-2">Niet meer beschikbaar</span>
                            }
                            <p class="mb-1">
                                <i class="bi bi-calendar-event"></i>
                                @abonnement.StartDatum.ToString("dd/MM/yyyy")
                                →
                                @abonnement.EindDatum.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <strong class="fs-5">€ @abonnement.Prijs.ToString("F2")</strong>
                            <span class="btn btn-dark btn-sm">In winkelwagen</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <p>Er is een fout</p>
}