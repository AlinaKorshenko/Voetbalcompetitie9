@model IEnumerable<ChampionsLeagueTickets.ViewModels.AbonnementenInformatieVM>
@{
    ViewData["Title"] = "Abonnementen";
}
@section Styles {
    <link href="~/lib/datatables/css/jquery.datatables.min.css" rel="stylesheet" />
}
@if (Model != null)
{
    <table id="abonnementenTable" class="table border-0">
        <thead>
            <tr>
                <th>Abonnementen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var abonnement in Model)
            {
                <tr class="match-card">
                    <td>
                        <a asp-controller="Abonnement"
                           asp-action="Kopen"
                           asp-route-stadionNaam="@abonnement.StadionNaam"
                           asp-route-seizoenNaam="@abonnement.SeizoenNaam"
                           class="text-decoration-none text-dark">
                            <div class="card p-3 shadow-sm mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-0">@abonnement.StadionNaam</h5>
                                    </div>
                                    <div>
                                        <span class="badge bg-dark mx-2">@abonnement.SeizoenNaam</span>
                                    </div>
                                    <div class="text-center">
                                        <span>@abonnement.StartDatum.ToString("dd/MM/yyyy")</span>
                                        <span class="mx-1">→</span>
                                        <span>@abonnement.EindDatum.ToString("dd/MM/yyyy")</span>
                                    </div>
                                    <div class="text-end">
                                        <strong>€ @abonnement.Prijs.ToString("F2")</strong>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Er is een fout</p>
}
@section Scripts {
    <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
    <script>
        $(() => {
            $('#abonnementenTable').DataTable();
        });
    </script>
}