@model List<ChampionsLeagueTickets.ViewModels.StadionVanTeamVM.StadionVanTeamVM>

@{
    ViewData["Title"] = "IndexAsync";
}

<h2 class="mb-4">Stadioninfo per club</h2>

<div class="accordion" id="teamsAccordion">
    @foreach (var team in Model)
    {
        var collapseId = "collapse-" + team.TeamNaam.Replace(" ", "").Replace(".", "");

        <div class="accordion-item mb-2 shadow-sm">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" 
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#@collapseId">

                    <div>
                        <strong>@team.TeamNaam</strong>
                        <span class="text-muted ms-2">
                            Stadion: @team.StadionNaam
                        </span>
                    </div>

                </button>
            </h2>

            <div id="@collapseId" 
                 class="accordion-collapse collapse"
                 data-bs-parent="#teamsAccordion">

                <div class="accordion-body">

                    <h5 class="mb-3">Stadioninformatie</h5>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p><strong>Stadion:</strong> @team.StadionNaam</p>
                            <p><strong>Land:</strong> @team.Land</p>
                            <p><strong>Adres:</strong> @team.Adres</p>
                        </div>

                        <div class="col-md-6">
                            <p><strong>Postcode:</strong> @team.Postcode</p>
                            <p><strong>Gemeente:</strong> @team.Gemeente</p>
                            <p><strong>Totale capaciteit:</strong> @team.AantalZitplaatsen</p>
                        </div>
                    </div>

                    <h5 class="mb-3">Vakken en capaciteit</h5>

                    @if (team.VakTypes != null && team.VakTypes.Any())
                    {
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Vak / Ring</th>
                                    <th>Capaciteit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vak in team.VakTypes)
                                {
                                    <tr>
                                        <td>@vak.VakTypeNaam</td>
                                        <td>@vak.Capaciteit zitplaatsen</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            Geen vakinformatie beschikbaar.
                        </div>
                    }

                </div>
            </div>
        </div>
    }
</div>