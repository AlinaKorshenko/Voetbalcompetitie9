@{
    ViewData["Title"] = "Bestelling bevestigd";
}

<div class="row justify-content-center text-center">
    <h1>@ViewData["Title"]</h1>

    <p class="mt-3">
        🎉 Uw bestelling is succesvol geplaatst!
    </p>

    @if (ViewBag.OrderId != null)
    {
        <p>
            <strong>Ordernummer:</strong> @ViewBag.OrderId
        </p>
    }

    <p>
        U ontvangt binnenkort een bevestigingsmail met alle details van uw aankoop.
    </p>

    <img src="~/images/spelende_voetballers.jpg"
         alt="Spelende voetballers"
         class="img-fluid rounded mt-3" />

    <div class="mt-4">
        <a asp-controller="Info" asp-action="Introductie" class="btn btn-primary">
            Terug naar home
        </a>
    </div>
</div>