@{
    ViewData["Title"] = "Bestelling bevestigd";
}
<div class="row justify-content-center text-center">
    <h1>@ViewData["Title"]</h1>
    <p class="mt-3">
        Uw bestelling is succesvol geplaatst!
    </p>
    <p>
        U ontvangt binnenkort een bevestigingsmail met alle details van uw aankoop.
    </p>
    <div class="d-flex justify-content-center gap-3 mt-2">
        <a asp-controller="Info" asp-action="Introductie" class="btn-golden">
            Terug naar home
        </a>
        <a asp-controller="Hotel" asp-action="Index" class="btn-golden">
            Dichtbijzijnde hotels
        </a>
    </div>
    <img src="~/images/blije_voetballers.jpg"
         alt="Blije voetballers"
         class="img-fluid rounded mt-4" />
</div>